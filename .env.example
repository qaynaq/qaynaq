# Qaynaq Configuration - copy to .env and adjust

# ====================
# Node Configuration
# ====================

# Node role (required). Uncomment one.
# ROLE=coordinator
# ROLE=worker

HTTP_PORT=8080
GRPC_PORT=50000
DEBUG_MODE=false

# ====================
# Database Configuration
# ====================

# SQLite (default). Quoted because the `&` would otherwise be
# interpreted by the shell when sourcing this file.
DATABASE_DRIVER=sqlite
DATABASE_URI="file:qaynaq.sqlite?_foreign_keys=1&mode=rwc"

# PostgreSQL (uncomment to use)
# DATABASE_DRIVER=postgres
# DATABASE_URI=postgres://qaynaq:qaynaq@postgres:5432/qaynaq?sslmode=disable

# PostgreSQL Service Configuration
POSTGRES_USER=qaynaq
POSTGRES_PASSWORD=qaynaq
POSTGRES_DB=qaynaq

# ====================
# Secret Configuration
# ====================

# Encryption key (must be exactly 32 bytes). Generate with:
#   openssl rand -base64 32 | cut -c1-32
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_32_BYTE_KEY

# ====================
# Authentication Configuration
# ====================

# Authentication type: none, basic, or oauth2
AUTH_TYPE=none

# ====================
# Basic Authentication
# ====================

# Uncomment to enable basic auth
# AUTH_BASIC_USERNAME=qaynaq
# AUTH_BASIC_PASSWORD=password

# ====================
# OAuth2 Authentication
# ====================

# Uncomment to enable OAuth2 (any OIDC provider; Qaynaq discovers endpoints from issuer)
# AUTH_OAUTH2_CLIENT_ID=qaynaq
# AUTH_OAUTH2_CLIENT_SECRET=qaynaq-secret-change-in-production
# AUTH_OAUTH2_ISSUER_URL=http://localhost:8090/realms/qaynaq
# AUTH_OAUTH2_SCOPES=openid,email,profile
# AUTH_OAUTH2_ALLOWED_USERS=
# AUTH_OAUTH2_ALLOWED_DOMAINS=
# AUTH_OAUTH2_SESSION_COOKIE_NAME=qaynaq_session

# Role mapping (optional). Without these, every signed-in user is Admin.
# AUTH_OAUTH2_ADMIN_USERS=alice@example.com,*@admin.example.com
# AUTH_OAUTH2_MCP_USERS=*@example.com
# AUTH_OAUTH2_ROLE_ATTRIBUTE_PATH="contains(groups[*], 'qaynaq-admins') && 'Admin' || (contains(groups[*], 'qaynaq-mcp') && 'MCP' || 'None')"

# ====================
# MCP OAuth
# ====================
# Expose OAuth 2.1 Authorization Server endpoints so MCP clients can
# authenticate via the standard MCP OAuth flow instead of static tokens.
# MCP_OAUTH_ENABLED=false

# ====================
# Worker Configuration
# ====================

WORKER_GRPC_PORT=50001
DISCOVERY_URI=localhost:50000
