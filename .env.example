# Qaynaq Configuration
# Copy this file to .env and configure your settings

# ====================
# General Configuration
# ====================

ROLE=coordinator
HTTP_PORT=8080
GRPC_PORT=50000
DISCOVERY_URI=coordinator:50000
DEBUG_MODE=false

# ====================
# Database Configuration
# ====================

# SQLite (default)
DATABASE_DRIVER=sqlite
DATABASE_URI=file:/qaynaq.sqlite?_foreign_keys=1&mode=rwc

# PostgreSQL (uncomment to use)
# DATABASE_DRIVER=postgres
# DATABASE_URI=postgres://qaynaq:qaynaq@postgres:5432/qaynaq?sslmode=disable

# PostgreSQL Service Configuration
POSTGRES_USER=qaynaq
POSTGRES_PASSWORD=qaynaq
POSTGRES_DB=qaynaq

# ====================
# Secret Configuration
# ====================

# Secret key for encryption (must be exactly 32 bytes)
SECRET_KEY=this_is_a_32_byte_key_for_AES!!!

# ====================
# Authentication Configuration
# ====================

# Authentication type: none, basic, or oauth2
AUTH_TYPE=none

# --------------------
# Basic Authentication
# --------------------

# Uncomment to enable basic auth
# AUTH_BASIC_USERNAME=qaynaq
# AUTH_BASIC_PASSWORD=password

# --------------------
# OAuth2 Authentication
# --------------------

# Uncomment to enable OAuth2
# AUTH_OAUTH2_CLIENT_ID=qaynaq
# AUTH_OAUTH2_CLIENT_SECRET=qaynaq-secret-change-in-production
# AUTH_OAUTH2_AUTHORIZATION_URL=http://localhost:8090/realms/qaynaq/protocol/openid-connect/auth
# AUTH_OAUTH2_TOKEN_URL=http://keycloak:8080/realms/qaynaq/protocol/openid-connect/token
# AUTH_OAUTH2_REDIRECT_URL=http://localhost:8080/auth/callback
# AUTH_OAUTH2_SCOPES=openid,email,profile
# AUTH_OAUTH2_USER_INFO_URL=http://keycloak:8080/realms/qaynaq/protocol/openid-connect/userinfo
# AUTH_OAUTH2_SESSION_SECRET=change-this-to-random-32-char-secret

# ====================
# Worker Configuration
# ====================

WORKER_GRPC_PORT=50001
